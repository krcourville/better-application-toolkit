{
  "name": "@batkit/express-middleware",
  "version": "0.1.0",
  "description": "Express middleware for error handling and request context (Node.js only)",
  "keywords": [
    "error-handling",
    "express",
    "middleware",
    "rfc9457",
    "typescript"
  ],
  "homepage": "https://github.com/YOUR_USERNAME/better-application-toolkit/tree/main/packages/express-middleware#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit/issues"
  },
  "license": "MIT",
  "author": "Ken Courville",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git",
    "directory": "packages/express-middleware"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && vp pack",
    "dev": "vp pack -w",
    "test": "vp test",
    "test:watch": "vp test -w",
    "typecheck": "tsc --noEmit",
    "lint": "vp check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@batkit/errors": "workspace:*",
    "@batkit/logger": "workspace:*",
    "@batkit/rfc9457": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "express": "^4.21.2",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
