{
  "name": "@batkit/logger",
  "version": "0.1.0",
  "description": "Logger facade with default console implementation for Node.js and browser",
  "keywords": [
    "console",
    "facade",
    "logger",
    "logging",
    "structured-logging",
    "typescript"
  ],
  "homepage": "https://github.com/YOUR_USERNAME/better-application-toolkit/tree/main/packages/logger#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit/issues"
  },
  "license": "MIT",
  "author": "Ken Courville",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git",
    "directory": "packages/logger"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./console": {
      "import": {
        "types": "./dist/console.d.ts",
        "default": "./dist/console.js"
      },
      "require": {
        "types": "./dist/console.d.cts",
        "default": "./dist/console.cjs"
      }
    },
    "./async-local": {
      "import": {
        "types": "./dist/async-local.d.ts",
        "default": "./dist/async-local.js"
      },
      "require": {
        "types": "./dist/async-local.d.cts",
        "default": "./dist/async-local.cjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && tsup && tsup --config tsup.async-local.config.ts",
    "dev": "concurrently -n main,als \"tsup --watch\" \"tsup --watch --config tsup.async-local.config.ts\"",
    "test": "vp test",
    "test:watch": "vp test -w",
    "typecheck": "tsc --noEmit",
    "lint": "vp check .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
