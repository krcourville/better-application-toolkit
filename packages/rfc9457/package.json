{
  "name": "@batkit/rfc9457",
  "version": "0.1.0",
  "description": "Zod schemas and TypeScript types for RFC 9457 (Problem Details for HTTP APIs)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist"
  },
  "keywords": ["rfc9457", "problem-details", "http", "api", "error", "zod", "validation"],
  "author": "Ken Courville",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git",
    "directory": "packages/rfc9457"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/better-application-toolkit/tree/main/packages/rfc9457#readme",
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
