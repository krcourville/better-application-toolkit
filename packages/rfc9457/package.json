{
  "name": "@batkit/rfc9457",
  "version": "0.1.0",
  "description": "Zod schemas and TypeScript types for RFC 9457 (Problem Details for HTTP APIs)",
  "keywords": [
    "api",
    "error",
    "http",
    "problem-details",
    "rfc9457",
    "validation",
    "zod"
  ],
  "homepage": "https://github.com/YOUR_USERNAME/better-application-toolkit/tree/main/packages/rfc9457#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit/issues"
  },
  "license": "MIT",
  "author": "Ken Courville",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git",
    "directory": "packages/rfc9457"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && vp pack",
    "dev": "vp pack -w",
    "test": "vp test",
    "test:watch": "vp test -w",
    "typecheck": "tsc --noEmit",
    "lint": "vp check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
