{
  "name": "@batkit/logger-pino",
  "version": "0.1.0",
  "description": "Pino.js implementation of @batkit/logger facade for Node.js and browser",
  "keywords": [
    "logger",
    "logging",
    "pino",
    "structured-logging",
    "typescript"
  ],
  "homepage": "https://github.com/YOUR_USERNAME/better-application-toolkit/tree/main/packages/logger-pino#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit/issues"
  },
  "license": "MIT",
  "author": "Ken Courville",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git",
    "directory": "packages/logger-pino"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && vp pack",
    "dev": "vp pack -w",
    "test": "vp test",
    "test:watch": "vp test -w",
    "typecheck": "tsc --noEmit",
    "lint": "vp check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@batkit/logger": "workspace:*",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
