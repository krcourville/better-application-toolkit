{
  "name": "@batkit/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "description": "Better Application Toolkit - Observability and reliability toolkit for Node.js applications",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules pnpm-lock.yaml .pnpm-store && turbo run clean",
    "dev": "pnpm -w run dev:express",
    "dev:watch": "npx concurrently \"pnpm -w run build\" \"pnpm -w run dev:express\" --names \"build,server\" --prefix \"[{name}]\" --kill-others-on-exit",
    "dev:express": "turbo run dev --filter=express-api",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "concurrently": "^8.2.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git"
  },
  "keywords": [
    "observability",
    "logging",
    "error-handling",
    "express",
    "middleware",
    "rfc9457",
    "toolkit"
  ],
  "author": "Ken Courville",
  "license": "MIT"
}
