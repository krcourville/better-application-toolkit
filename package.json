{
  "name": "@batkit/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Better Application Toolkit - Observability and reliability toolkit for Node.js applications",
  "keywords": [
    "error-handling",
    "express",
    "logging",
    "middleware",
    "observability",
    "rfc9457",
    "toolkit"
  ],
  "license": "MIT",
  "author": "Ken Courville",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/better-application-toolkit.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "vp run -r --cache build",
    "build:clean": "vp run -r clean && tsc --build --clean",
    "test": "vp run -r --cache test",
    "test:watch": "vp test -w",
    "check": "vp check",
    "lint": "vp check",
    "lint:fix": "vp check --fix",
    "typecheck": "vp run -r --cache typecheck",
    "clean": "rm -rf node_modules pnpm-lock.yaml .pnpm-store && vp run -r clean",
    "dev": "LOCAL_DEV=true vp run --filter express-api... dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "vp run -r --cache build && changeset publish",
    "stop-server": "lsof -ti :3785 | xargs kill -9",
    "cli": "vp run -t cli-app#build && vp run --filter cli-app dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2",
    "yaml": "^2.4.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
