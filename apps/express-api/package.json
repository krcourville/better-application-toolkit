{
  "name": "express-api",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Express.js API demonstrating all @batkit packages",
  "type": "module",
  "scripts": {
    "dev": "esno --env-file=.env.dev --watch src/index.ts",
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "vp check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anatine/zod-openapi": "^1.12.0",
    "@batkit/errors": "workspace:*",
    "@batkit/express-middleware": "workspace:*",
    "@batkit/logger": "workspace:*",
    "@batkit/logger-pino": "workspace:*",
    "@batkit/rfc9457": "workspace:*",
    "@scalar/express-api-reference": "^0.8.46",
    "@ts-rest/core": "^3.30.5",
    "@ts-rest/express": "^3.30.5",
    "@ts-rest/open-api": "^3.30.5",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "esno": "^4.8.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.14"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
